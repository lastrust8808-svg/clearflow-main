# Port for the backend Express server
PORT=8000

# Plaid API Credentials (from https://dashboard.plaid.com/team/keys)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Public URL for your backend server. Use your ngrok URL during development.
# This MUST be an https URL for Plaid webhooks in sandbox.
PLAID_WEBHOOK_URL=

# Secret key for encrypting sensitive data like Plaid access tokens.
# Generate a secure, random 32-character string for production.
ENCRYPTION_KEY=a-secret-key-for-dev-only-32-bytes

# Google OAuth 2.0 Client ID
VITE_GOOGLE_CLIENT_ID=

# API Base URL
VITE_API_BASE_URL=
