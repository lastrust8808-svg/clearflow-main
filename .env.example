# Port for the backend Express server
PORT=8000

# Plaid API Credentials (from https://dashboard.plaid.com/team/keys)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Public URL for your backend server. Use your ngrok URL during development.
# This MUST be an https URL for Plaid webhooks in sandbox.
PLAID_WEBHOOK_URL=

# Secret key for encrypting sensitive data like Plaid access tokens.
# Generate a secure, random 32-character string for production.
ENCRYPTION_KEY=a-secret-key-for-dev-only-32-bytes

# Google OAuth 2.0 Client ID
VITE_GOOGLE_CLIENT_ID=

# API Base URL
VITE_API_BASE_URL=

# SMTP settings for direct invoice email delivery.
# Example:
# SMTP_HOST=smtp.yourdomain.com
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=invoices@yourdomain.com
# SMTP_PASS=your-app-password
# SMTP_FROM_EMAIL=invoices@yourdomain.com
# SMTP_FROM_NAME=ClearFlow Billing
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# SMS provider settings for backup phone verification.
# Example using Twilio:
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN=your-auth-token
# TWILIO_FROM_NUMBER=+15555555555
SMS_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
